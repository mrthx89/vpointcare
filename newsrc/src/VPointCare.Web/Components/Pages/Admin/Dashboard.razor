@page "/admin"
@attribute [Authorize]
@inject DashboardQueryService DashboardQuery
@inject ActiveAgentTracker ActiveAgentTracker

<PageTitle>Dashboard - VPoint Care</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h5">Dashboard</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Ringkasan operasional WhatsApp, AI, dan agent aktif.</MudText>
    </div>

    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="metric-tile" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.MarkUnreadChatAlt" />
                <span>Total Chat</span>
                <strong>@_snapshot.TotalChats</strong>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="metric-tile" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.NotificationsActive" />
                <span>Belum Dibaca</span>
                <strong>@_snapshot.UnreadMessages</strong>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="metric-tile" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.Groups" />
                <span>Grup WhatsApp</span>
                <strong>@_snapshot.GroupChats</strong>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Class="metric-tile" Elevation="0">
                <MudIcon Icon="@Icons.Material.Filled.SupportAgent" />
                <span>CS Aktif</span>
                <strong>@_agents.ActiveCount</strong>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Class="section-panel" Elevation="0">
                <MudText Typo="Typo.subtitle1">Aktivitas Hari Ini</MudText>
                <MudList T="string" Dense="true">
                    <MudListItem Icon="@Icons.Material.Filled.Inbox">Pesan masuk: @_snapshot.IncomingToday</MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.SmartToy">Chat auto reply aktif: @_snapshot.ActiveAiChats</MudListItem>
                    <MudListItem Icon="@Icons.Material.Filled.AutoAwesome">Balasan AI tersimpan: @_snapshot.AiReplies</MudListItem>
                </MudList>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="section-panel" Elevation="0">
                <MudText Typo="Typo.subtitle1">Agent Sedang Online</MudText>
                @if (_agents.Agents.Count == 0)
                {
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Belum ada koneksi SignalR aktif.</MudText>
                }
                else
                {
                    <MudList T="ActiveAgentPayload" Dense="true">
                        @foreach (var agent in _agents.Agents)
                        {
                            <MudListItem Icon="@Icons.Material.Filled.Circle">@agent.Name</MudListItem>
                        }
                    </MudList>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private DashboardSnapshot _snapshot = new(0, 0, 0, 0, 0, 0);
    private AgentsUpdatedPayload _agents = new(0, Array.Empty<ActiveAgentPayload>());

    protected override async Task OnInitializedAsync()
    {
        _snapshot = await DashboardQuery.GetSnapshotAsync();
        _agents = ActiveAgentTracker.Snapshot();
    }
}
