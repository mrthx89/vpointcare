@page "/admin/log-data"
@attribute [Authorize]
@inject VPointCare.Web.Data.VPointCareDbContext Db
@using Microsoft.EntityFrameworkCore

<PageTitle>Log Data - VPoint Care</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h5">Log Data</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Monitoring webhook WAHA, integrasi, aktivitas, dan error aplikasi.</MudText>
    </div>

    <MudGrid>
        <MudItem xs="12" sm="6" md="3"><MudPaper Class="metric-tile" Elevation="0"><MudIcon Icon="@Icons.Material.Filled.Webhook" /><span>Webhook</span><strong>@_webhookCount</strong></MudPaper></MudItem>
        <MudItem xs="12" sm="6" md="3"><MudPaper Class="metric-tile" Elevation="0"><MudIcon Icon="@Icons.Material.Filled.SyncAlt" /><span>Integrasi</span><strong>@_integrationCount</strong></MudPaper></MudItem>
        <MudItem xs="12" sm="6" md="3"><MudPaper Class="metric-tile" Elevation="0"><MudIcon Icon="@Icons.Material.Filled.History" /><span>Aktivitas</span><strong>@_activityCount</strong></MudPaper></MudItem>
        <MudItem xs="12" sm="6" md="3"><MudPaper Class="metric-tile" Elevation="0"><MudIcon Icon="@Icons.Material.Filled.ErrorOutline" /><span>Error</span><strong>@_errorCount</strong></MudPaper></MudItem>
    </MudGrid>

    <MudGrid>
        <MudItem xs="12" md="6">
            <MudPaper Class="section-panel" Elevation="0"><MudText Typo="Typo.subtitle1">Webhook WAHA Terakhir</MudText>
                <MudTable T="VPointCare.Web.Data.Entities.TLogWebhookWaha" Items="@_webhooks" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" RowsPerPage="10" Filter="FilterWebhook">
                    <ToolBarContent>
                        <MudText Typo="Typo.subtitle1">Webhook WAHA</MudText>
                        <MudSpacer />
                        <MudTextField @bind-Value="_webhookSearch" Placeholder="Filter data" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Margin="Margin.Dense" Variant="Variant.Outlined" />
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.TLogWebhookWaha, object>(x => x.JenisEvent)">Event</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.TLogWebhookWaha, object>(x => x.SudahDiproses)">Diproses</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.TLogWebhookWaha, object>(x => x.TglDiterima)">Diterima</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.TLogWebhookWaha, object?>(x => x.PesanError)">Error</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Event">@context.JenisEvent</MudTd>
                        <MudTd DataLabel="Diproses">@(context.SudahDiproses ? "Ya" : "Belum")</MudTd>
                        <MudTd DataLabel="Diterima">@context.TglDiterima.ToString("dd/MM HH:mm")</MudTd>
                        <MudTd DataLabel="Error">@(context.PesanError ?? "-")</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new[] { 10, 25, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" md="6">
            <MudPaper Class="section-panel" Elevation="0"><MudText Typo="Typo.subtitle1">Integrasi Terakhir</MudText>
                <MudTable T="VPointCare.Web.Data.Entities.TLogIntegrasi" Items="@_integrations" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" RowsPerPage="10" Filter="FilterIntegration">
                    <ToolBarContent>
                        <MudText Typo="Typo.subtitle1">Log Integrasi</MudText>
                        <MudSpacer />
                        <MudTextField @bind-Value="_integrationSearch" Placeholder="Filter data" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Margin="Margin.Dense" Variant="Variant.Outlined" />
                    </ToolBarContent>
                    <HeaderContent>
                        <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.TLogIntegrasi, object>(x => x.KodeIntegrasi)">Kode</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.TLogIntegrasi, object?>(x => x.StatusHttp)">HTTP</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.TLogIntegrasi, object>(x => x.Berhasil)">Berhasil</MudTableSortLabel></MudTh>
                        <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.TLogIntegrasi, object>(x => x.TglRequest)">Waktu</MudTableSortLabel></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Kode">@context.KodeIntegrasi</MudTd>
                        <MudTd DataLabel="HTTP">@(context.StatusHttp?.ToString() ?? "-")</MudTd>
                        <MudTd DataLabel="Berhasil">@(context.Berhasil ? "Ya" : "Tidak")</MudTd>
                        <MudTd DataLabel="Waktu">@context.TglRequest.ToString("dd/MM HH:mm")</MudTd>
                    </RowTemplate>
                    <PagerContent>
                        <MudTablePager PageSizeOptions="new[] { 10, 25, 50, 100 }" />
                    </PagerContent>
                </MudTable>
            </MudPaper>
        </MudItem>
    </MudGrid>
</MudStack>

@code {
    private int _webhookCount;
    private int _integrationCount;
    private int _activityCount;
    private int _errorCount;
    private List<VPointCare.Web.Data.Entities.TLogWebhookWaha> _webhooks = [];
    private List<VPointCare.Web.Data.Entities.TLogIntegrasi> _integrations = [];
    private string _webhookSearch = "";
    private string _integrationSearch = "";

    protected override async Task OnInitializedAsync()
    {
        _webhookCount = await Db.LogWebhookWahas.CountAsync();
        _integrationCount = await Db.LogIntegrasis.CountAsync();
        _activityCount = await Db.TLogAktivitasSet.CountAsync();
        _errorCount = await Db.TLogErrorSet.CountAsync();
        _webhooks = await Db.LogWebhookWahas.AsNoTracking().OrderByDescending(x => x.TglDiterima).Take(20).ToListAsync();
        _integrations = await Db.LogIntegrasis.AsNoTracking().OrderByDescending(x => x.TglRequest).Take(20).ToListAsync();
    }

    private bool FilterWebhook(VPointCare.Web.Data.Entities.TLogWebhookWaha row)
    {
        if (string.IsNullOrWhiteSpace(_webhookSearch))
        {
            return true;
        }

        return Contains(row.JenisEvent, _webhookSearch)
            || Contains(row.SudahDiproses ? "Ya" : "Belum", _webhookSearch)
            || Contains(row.TglDiterima.ToString("dd/MM HH:mm"), _webhookSearch)
            || Contains(row.PesanError, _webhookSearch)
            || Contains(row.PayloadJson, _webhookSearch);
    }

    private bool FilterIntegration(VPointCare.Web.Data.Entities.TLogIntegrasi row)
    {
        if (string.IsNullOrWhiteSpace(_integrationSearch))
        {
            return true;
        }

        return Contains(row.KodeIntegrasi, _integrationSearch)
            || Contains(row.StatusHttp?.ToString(), _integrationSearch)
            || Contains(row.Berhasil ? "Ya" : "Tidak", _integrationSearch)
            || Contains(row.TglRequest.ToString("dd/MM HH:mm"), _integrationSearch)
            || Contains(row.PesanError, _integrationSearch)
            || Contains(row.RequestJson, _integrationSearch)
            || Contains(row.ResponseJson, _integrationSearch);
    }

    private static bool Contains(string? value, string search) => value?.Contains(search, StringComparison.OrdinalIgnoreCase) == true;
}
