@page "/admin/master-customer/nomor-whatsapp"
@attribute [Authorize]
@inject VPointCare.Web.Data.VPointCareDbContext Db
@using Microsoft.EntityFrameworkCore

<PageTitle>Nomor WhatsApp - VPoint Care</PageTitle>

<MudStack Spacing="3">
    <div class="page-heading-row">
        <div><MudText Typo="Typo.h5">Nomor WhatsApp</MudText><MudText Typo="Typo.body2" Color="Color.Secondary">Mapping nomor WhatsApp ke customer dan instansi.</MudText></div>
        <MudButton Href="/admin/master-customer" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack">Ringkasan</MudButton>
    </div>
    <MudPaper Class="section-panel" Elevation="0">
        <MudTable T="NomorRow" Items="@_rows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" RowsPerPage="10" Filter="FilterRow">
            <ToolBarContent>
                <MudText Typo="Typo.subtitle1">Data Nomor WhatsApp</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_search" Placeholder="Filter data" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Margin="Margin.Dense" Variant="Variant.Outlined" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<NomorRow, object>(x => x.Nomor)">Nomor</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<NomorRow, object?>(x => x.NamaKontak)">Nama Kontak</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<NomorRow, object>(x => x.Customer)">Customer</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<NomorRow, object>(x => x.Instansi)">Instansi</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<NomorRow, object>(x => x.Utama)">Utama</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<NomorRow, object>(x => x.Terverifikasi)">Verifikasi</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Nomor">@context.Nomor</MudTd>
                <MudTd DataLabel="Nama Kontak">@context.NamaKontak</MudTd>
                <MudTd DataLabel="Customer">@context.Customer</MudTd>
                <MudTd DataLabel="Instansi">@context.Instansi</MudTd>
                <MudTd DataLabel="Utama">@(context.Utama ? "Ya" : "Tidak")</MudTd>
                <MudTd DataLabel="Verifikasi">@(context.Terverifikasi ? "Ya" : "Tidak")</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 10, 25, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private List<NomorRow> _rows = [];
    private string _search = "";

    protected override async Task OnInitializedAsync()
    {
        _rows = await (from n in Db.MNomorWhatsappSet.AsNoTracking()
            join c in Db.MCustomerSet.AsNoTracking() on n.IdCustomer equals c.Id into customerJoin
            from c in customerJoin.DefaultIfEmpty()
            join i in Db.MInstansiSet.AsNoTracking() on n.IdInstansi equals i.Id into instansiJoin
            from i in instansiJoin.DefaultIfEmpty()
            orderby n.NamaKontak
            select new NomorRow(n.NomorWhatsapp, n.NamaKontak, c == null ? "-" : c.NamaCustomer, i == null ? "-" : i.NamaInstansi, n.NomorUtama, n.Terverifikasi))
            .ToListAsync();
    }

    private bool FilterRow(NomorRow row)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }

        return Contains(row.Nomor)
            || Contains(row.NamaKontak)
            || Contains(row.Customer)
            || Contains(row.Instansi)
            || Contains(row.Utama ? "Ya" : "Tidak")
            || Contains(row.Terverifikasi ? "Ya" : "Tidak");
    }

    private bool Contains(string? value) => value?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true;

    private sealed record NomorRow(string Nomor, string? NamaKontak, string Customer, string Instansi, bool Utama, bool Terverifikasi);
}
