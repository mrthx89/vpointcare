@page "/admin/master-customer/customers"
@attribute [Authorize]
@inject VPointCare.Web.Data.VPointCareDbContext Db
@using Microsoft.EntityFrameworkCore

<PageTitle>Kontak Customer - VPoint Care</PageTitle>

<MudStack Spacing="3">
    <div class="page-heading-row">
        <div><MudText Typo="Typo.h5">Kontak Customer</MudText><MudText Typo="Typo.body2" Color="Color.Secondary">Data `MCustomer` dan relasinya ke instansi.</MudText></div>
        <MudButton Href="/admin/master-customer" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack">Ringkasan</MudButton>
    </div>
    <MudPaper Class="section-panel" Elevation="0">
        <MudTable T="CustomerRow" Items="@_rows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" RowsPerPage="10" Filter="FilterRow">
            <ToolBarContent>
                <MudText Typo="Typo.subtitle1">Data Kontak Customer</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_search" Placeholder="Filter data" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Margin="Margin.Dense" Variant="Variant.Outlined" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<CustomerRow, object>(x => x.Kode)">Kode</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CustomerRow, object>(x => x.Nama)">Nama</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CustomerRow, object>(x => x.Instansi)">Instansi</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CustomerRow, object?>(x => x.Email)">Email</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CustomerRow, object?>(x => x.Telepon)">Telepon</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<CustomerRow, object?>(x => x.Jabatan)">Jabatan</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Kode">@context.Kode</MudTd>
                <MudTd DataLabel="Nama">@context.Nama</MudTd>
                <MudTd DataLabel="Instansi">@context.Instansi</MudTd>
                <MudTd DataLabel="Email">@context.Email</MudTd>
                <MudTd DataLabel="Telepon">@context.Telepon</MudTd>
                <MudTd DataLabel="Jabatan">@context.Jabatan</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 10, 25, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private List<CustomerRow> _rows = [];
    private string _search = "";

    protected override async Task OnInitializedAsync()
    {
        _rows = await (from c in Db.MCustomerSet.AsNoTracking()
            join i in Db.MInstansiSet.AsNoTracking() on c.IdInstansi equals i.Id into instansiJoin
            from i in instansiJoin.DefaultIfEmpty()
            orderby c.NamaCustomer
            select new CustomerRow(c.KodeCustomer, c.NamaCustomer, i == null ? "-" : i.NamaInstansi, c.Email, c.Telepon, c.Jabatan))
            .ToListAsync();
    }

    private bool FilterRow(CustomerRow row)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }

        return Contains(row.Kode)
            || Contains(row.Nama)
            || Contains(row.Instansi)
            || Contains(row.Email)
            || Contains(row.Telepon)
            || Contains(row.Jabatan);
    }

    private bool Contains(string? value) => value?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true;

    private sealed record CustomerRow(string Kode, string Nama, string Instansi, string? Email, string? Telepon, string? Jabatan);
}
