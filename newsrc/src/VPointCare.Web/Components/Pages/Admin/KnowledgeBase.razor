@page "/admin/ai-agent/knowledge-base"
@attribute [Authorize]
@inject VPointCare.Web.Data.VPointCareDbContext Db
@using Microsoft.EntityFrameworkCore

<PageTitle>Knowledge Base AI - VPoint Care</PageTitle>

<MudStack Spacing="3">
    <div class="page-heading-row">
        <div><MudText Typo="Typo.h5">Knowledge Base AI</MudText><MudText Typo="Typo.body2" Color="Color.Secondary">Data `MPengetahuan` yang dipakai `AiAutoReplyService`.</MudText></div>
        <MudButton Href="/admin/ai-agent" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack">AI Agent</MudButton>
    </div>
    <MudPaper Class="section-panel" Elevation="0">
        <MudTable T="VPointCare.Web.Data.Entities.MPengetahuan" Items="@_rows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" RowsPerPage="10" Filter="FilterRow">
            <ToolBarContent>
                <MudText Typo="Typo.subtitle1">Data Knowledge Base</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_search" Placeholder="Filter data" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Margin="Margin.Dense" Variant="Variant.Outlined" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.MPengetahuan, object>(x => x.KodePengetahuan)">Kode</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.MPengetahuan, object>(x => x.JudulPengetahuan)">Judul</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.MPengetahuan, object?>(x => x.Tag)">Tag</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.MPengetahuan, object>(x => x.NonAktif)">Status</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Kode">@context.KodePengetahuan</MudTd>
                <MudTd DataLabel="Judul">@context.JudulPengetahuan</MudTd>
                <MudTd DataLabel="Tag">@context.Tag</MudTd>
                <MudTd DataLabel="Status">@(context.NonAktif ? "Nonaktif" : "Aktif")</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 10, 25, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private List<VPointCare.Web.Data.Entities.MPengetahuan> _rows = [];
    private string _search = "";

    protected override async Task OnInitializedAsync() => _rows = await Db.MPengetahuanSet.AsNoTracking().OrderBy(x => x.JudulPengetahuan).ToListAsync();

    private bool FilterRow(VPointCare.Web.Data.Entities.MPengetahuan row)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }

        return Contains(row.KodePengetahuan)
            || Contains(row.JudulPengetahuan)
            || Contains(row.Tag)
            || Contains(row.IsiPengetahuan)
            || Contains(row.NonAktif ? "Nonaktif" : "Aktif");
    }

    private bool Contains(string? value) => value?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true;
}
