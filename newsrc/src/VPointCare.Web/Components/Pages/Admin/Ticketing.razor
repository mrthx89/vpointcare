@page "/admin/ticketing"
@attribute [Authorize]
@inject VPointCare.Web.Data.VPointCareDbContext Db
@using Microsoft.EntityFrameworkCore

<PageTitle>Ticketing - VPoint Care</PageTitle>

<MudStack Spacing="3">
    <div class="page-heading-row">
        <div>
            <MudText Typo="Typo.h5">Ticketing</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Daftar ticket dari chat, prioritas, status, dan assignment developer.</MudText>
        </div>
        <MudChip T="string" Color="Color.Info" Variant="Variant.Filled">@_totalTicket ticket</MudChip>
    </div>

    <MudGrid>
        <MudItem xs="12" sm="6" md="3"><MudPaper Class="metric-tile" Elevation="0"><MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" /><span>Total</span><strong>@_totalTicket</strong></MudPaper></MudItem>
        <MudItem xs="12" sm="6" md="3"><MudPaper Class="metric-tile" Elevation="0"><MudIcon Icon="@Icons.Material.Filled.PendingActions" /><span>Aktif</span><strong>@_openTicket</strong></MudPaper></MudItem>
        <MudItem xs="12" sm="6" md="3"><MudPaper Class="metric-tile" Elevation="0"><MudIcon Icon="@Icons.Material.Filled.AssignmentInd" /><span>Ditugaskan</span><strong>@_assignedTicket</strong></MudPaper></MudItem>
        <MudItem xs="12" sm="6" md="3"><MudPaper Class="metric-tile" Elevation="0"><MudIcon Icon="@Icons.Material.Filled.DoneAll" /><span>Selesai</span><strong>@_closedTicket</strong></MudPaper></MudItem>
    </MudGrid>

    <MudPaper Class="section-panel" Elevation="0">
        <MudText Typo="Typo.subtitle1">Ticket Terakhir</MudText>
        <MudTable T="TicketRow" Items="@_tickets" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" RowsPerPage="10" Filter="FilterRow">
            <ToolBarContent>
                <MudText Typo="Typo.subtitle1">Data Ticket</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_search" Placeholder="Filter data" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Margin="Margin.Dense" Variant="Variant.Outlined" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<TicketRow, object>(x => x.NomorTicket)">No Ticket</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TicketRow, object>(x => x.JudulTicket)">Judul</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TicketRow, object>(x => x.Status)">Status</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TicketRow, object>(x => x.Prioritas)">Prioritas</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<TicketRow, object>(x => x.TglBuat)">Dibuat</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="No Ticket">@context.NomorTicket</MudTd>
                <MudTd DataLabel="Judul">@context.JudulTicket</MudTd>
                <MudTd DataLabel="Status">@context.Status</MudTd>
                <MudTd DataLabel="Prioritas">@context.Prioritas</MudTd>
                <MudTd DataLabel="Dibuat">@context.TglBuat.ToString("dd/MM/yyyy HH:mm")</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 10, 25, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private int _totalTicket;
    private int _openTicket;
    private int _assignedTicket;
    private int _closedTicket;
    private List<TicketRow> _tickets = [];
    private string _search = "";

    protected override async Task OnInitializedAsync()
    {
        _totalTicket = await Db.TTicketSet.CountAsync();
        _openTicket = await Db.TTicketSet.CountAsync(x => x.TglDitutup == null && x.TglSelesai == null);
        _assignedTicket = await Db.TTicketSet.CountAsync(x => x.DitugaskanKepada != null);
        _closedTicket = await Db.TTicketSet.CountAsync(x => x.TglDitutup != null || x.TglSelesai != null);

        _tickets = await (
            from t in Db.TTicketSet.AsNoTracking()
            join s in Db.MStatusTicketSet.AsNoTracking() on t.IdStatusTicket equals s.Id into statusJoin
            from s in statusJoin.DefaultIfEmpty()
            join p in Db.MPrioritasTicketSet.AsNoTracking() on t.IdPrioritasTicket equals p.Id into priorityJoin
            from p in priorityJoin.DefaultIfEmpty()
            orderby t.TglBuat descending
            select new TicketRow(t.NomorTicket, t.JudulTicket, s == null ? "-" : s.NamaStatusTicket, p == null ? "-" : p.NamaPrioritas, t.TglBuat))
            .ToListAsync();
    }

    private bool FilterRow(TicketRow row)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }

        return Contains(row.NomorTicket)
            || Contains(row.JudulTicket)
            || Contains(row.Status)
            || Contains(row.Prioritas)
            || Contains(row.TglBuat.ToString("dd/MM/yyyy HH:mm"));
    }

    private bool Contains(string? value) => value?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true;

    private sealed record TicketRow(string NomorTicket, string JudulTicket, string Status, string Prioritas, DateTime TglBuat);
}
