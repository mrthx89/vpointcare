@page "/admin/master-customer/hari-libur"
@attribute [Authorize]
@inject VPointCare.Web.Data.VPointCareDbContext Db
@using Microsoft.EntityFrameworkCore

<PageTitle>Hari Libur - VPoint Care</PageTitle>

<MudStack Spacing="3">
    <div class="page-heading-row">
        <div><MudText Typo="Typo.h5">Hari Libur</MudText><MudText Typo="Typo.body2" Color="Color.Secondary">Dipakai AI auto reply dan notifikasi internal agar mengikuti hari kerja.</MudText></div>
        <MudButton Href="/admin/ai-agent" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack">AI Agent</MudButton>
    </div>
    <MudPaper Class="section-panel" Elevation="0">
        <MudTable T="VPointCare.Web.Data.Entities.MHariLibur" Items="@_rows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" RowsPerPage="10" Filter="FilterRow">
            <ToolBarContent>
                <MudText Typo="Typo.subtitle1">Data Hari Libur</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_search" Placeholder="Filter data" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Margin="Margin.Dense" Variant="Variant.Outlined" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.MHariLibur, object>(x => x.TanggalLibur)">Tanggal</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.MHariLibur, object>(x => x.NamaHariLibur)">Nama</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.MHariLibur, object>(x => x.BerlakuTahunan)">Tahunan</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.MHariLibur, object>(x => x.NonAktif)">Status</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.MHariLibur, object?>(x => x.Keterangan)">Keterangan</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Tanggal">@context.TanggalLibur.ToString("dd/MM/yyyy")</MudTd>
                <MudTd DataLabel="Nama">@context.NamaHariLibur</MudTd>
                <MudTd DataLabel="Tahunan">@(context.BerlakuTahunan ? "Ya" : "Tidak")</MudTd>
                <MudTd DataLabel="Status">@(context.NonAktif ? "Nonaktif" : "Aktif")</MudTd>
                <MudTd DataLabel="Keterangan">@context.Keterangan</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 10, 25, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private List<VPointCare.Web.Data.Entities.MHariLibur> _rows = [];
    private string _search = "";

    protected override async Task OnInitializedAsync() => _rows = await Db.MHariLiburSet.AsNoTracking().OrderBy(x => x.TanggalLibur).ToListAsync();

    private bool FilterRow(VPointCare.Web.Data.Entities.MHariLibur row)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }

        return Contains(row.TanggalLibur.ToString("dd/MM/yyyy"))
            || Contains(row.NamaHariLibur)
            || Contains(row.Keterangan)
            || Contains(row.BerlakuTahunan ? "Ya" : "Tidak")
            || Contains(row.NonAktif ? "Nonaktif" : "Aktif");
    }

    private bool Contains(string? value) => value?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true;
}
