@page "/admin/master-customer/anggota-grup"
@attribute [Authorize]
@inject VPointCare.Web.Data.VPointCareDbContext Db
@using Microsoft.EntityFrameworkCore

<PageTitle>Anggota Grup - VPoint Care</PageTitle>

<MudStack Spacing="3">
    <div class="page-heading-row">
        <div><MudText Typo="Typo.h5">Anggota Grup</MudText><MudText Typo="Typo.body2" Color="Color.Secondary">Padanan resource Filament `AnggotaGrupWhatsappResource`.</MudText></div>
        <MudButton Href="/admin/master-customer" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack">Ringkasan</MudButton>
    </div>
    <MudPaper Class="section-panel" Elevation="0">
        <MudTable T="Row" Items="@_rows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" RowsPerPage="10" Filter="FilterRow">
            <ToolBarContent>
                <MudText Typo="Typo.subtitle1">Data Anggota Grup</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_search" Placeholder="Filter data" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Margin="Margin.Dense" Variant="Variant.Outlined" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<Row, object>(x => x.Grup)">Grup</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<Row, object>(x => x.Nomor)">Nomor</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<Row, object>(x => x.Customer)">Customer</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<Row, object>(x => x.Peran)">Peran</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<Row, object>(x => x.NonAktif)">Status</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Grup">@context.Grup</MudTd>
                <MudTd DataLabel="Nomor">@context.Nomor</MudTd>
                <MudTd DataLabel="Customer">@context.Customer</MudTd>
                <MudTd DataLabel="Peran">@context.Peran</MudTd>
                <MudTd DataLabel="Status">@(context.NonAktif ? "Nonaktif" : "Aktif")</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 10, 25, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private List<Row> _rows = [];
    private string _search = "";

    protected override async Task OnInitializedAsync()
    {
        _rows = await (from a in Db.MAnggotaGrupWhatsappSet.AsNoTracking()
            join g in Db.MGrupWhatsappSet.AsNoTracking() on a.IdGrupWhatsapp equals g.Id
            join n in Db.MNomorWhatsappSet.AsNoTracking() on a.IdNomorWhatsapp equals n.Id
            join c in Db.MCustomerSet.AsNoTracking() on a.IdCustomer equals c.Id into customerJoin
            from c in customerJoin.DefaultIfEmpty()
            orderby g.NamaGrup, n.NamaKontak
            select new Row(g.NamaGrup, n.NomorWhatsapp, c == null ? "-" : c.NamaCustomer, a.PeranAnggota ?? "-", a.NonAktif))
            .ToListAsync();
    }

    private bool FilterRow(Row row)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }

        return Contains(row.Grup)
            || Contains(row.Nomor)
            || Contains(row.Customer)
            || Contains(row.Peran)
            || Contains(row.NonAktif ? "Nonaktif" : "Aktif");
    }

    private bool Contains(string? value) => value?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true;

    private sealed record Row(string Grup, string Nomor, string Customer, string Peran, bool NonAktif);
}
