@page "/admin/master-customer"
@attribute [Authorize]
@inject VPointCare.Web.Data.VPointCareDbContext Db
@using Microsoft.EntityFrameworkCore

<PageTitle>Master Customer - VPoint Care</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h5">Master Customer</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Ringkasan instansi, kontak customer, nomor WhatsApp, grup, anggota, dan produk customer.</MudText>
    </div>

    <MudGrid>
        <MudItem xs="12" sm="6" md="3"><MudPaper Class="metric-tile" Elevation="0"><MudIcon Icon="@Icons.Material.Filled.Business" /><span>Instansi</span><strong>@_instansi</strong></MudPaper></MudItem>
        <MudItem xs="12" sm="6" md="3"><MudPaper Class="metric-tile" Elevation="0"><MudIcon Icon="@Icons.Material.Filled.Groups" /><span>Customer</span><strong>@_customer</strong></MudPaper></MudItem>
        <MudItem xs="12" sm="6" md="3"><MudPaper Class="metric-tile" Elevation="0"><MudIcon Icon="@Icons.Material.Filled.PhoneIphone" /><span>Nomor WA</span><strong>@_nomor</strong></MudPaper></MudItem>
        <MudItem xs="12" sm="6" md="3"><MudPaper Class="metric-tile" Elevation="0"><MudIcon Icon="@Icons.Material.Filled.Forum" /><span>Grup WA</span><strong>@_grup</strong></MudPaper></MudItem>
    </MudGrid>

    <MudPaper Class="section-panel" Elevation="0">
        <div class="section-header-row">
            <MudText Typo="Typo.subtitle1">Navigasi Master</MudText>
            <div class="button-row">
                <MudButton Href="/admin/master-customer/instansi" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Business">Instansi</MudButton>
                <MudButton Href="/admin/master-customer/customers" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Groups">Customer</MudButton>
                <MudButton Href="/admin/master-customer/nomor-whatsapp" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.PhoneIphone">Nomor WA</MudButton>
                <MudButton Href="/admin/master-customer/grup-whatsapp" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Forum">Grup WA</MudButton>
                <MudButton Href="/admin/master-customer/anggota-grup" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.GroupAdd">Anggota Grup</MudButton>
                <MudButton Href="/admin/master-customer/hari-libur" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.EventBusy">Hari Libur</MudButton>
            </div>
        </div>
    </MudPaper>

    <MudPaper Class="section-panel" Elevation="0">
        <MudText Typo="Typo.subtitle1">Instansi Terakhir Sinkron</MudText>
        <MudTable T="VPointCare.Web.Data.Entities.MInstansi" Items="@_latestInstansi" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" RowsPerPage="10" Filter="FilterInstansi">
            <ToolBarContent>
                <MudText Typo="Typo.subtitle1">Data Sinkron Terakhir</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_search" Placeholder="Filter data" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Margin="Margin.Dense" Variant="Variant.Outlined" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.MInstansi, object>(x => x.KodeInstansi)">Kode</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.MInstansi, object>(x => x.NamaInstansi)">Nama</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.MInstansi, object?>(x => x.Kota)">Kota</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.MInstansi, object?>(x => x.SumberData)">Sumber</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<VPointCare.Web.Data.Entities.MInstansi, object?>(x => x.TglSinkronTerakhir)">Sinkron</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Kode">@context.KodeInstansi</MudTd>
                <MudTd DataLabel="Nama">@context.NamaInstansi</MudTd>
                <MudTd DataLabel="Kota">@context.Kota</MudTd>
                <MudTd DataLabel="Sumber">@context.SumberData</MudTd>
                <MudTd DataLabel="Sinkron">@(context.TglSinkronTerakhir?.ToString("dd/MM/yyyy HH:mm") ?? "-")</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 10, 25, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private int _instansi;
    private int _customer;
    private int _nomor;
    private int _grup;
    private List<VPointCare.Web.Data.Entities.MInstansi> _latestInstansi = [];
    private string _search = "";

    protected override async Task OnInitializedAsync()
    {
        _instansi = await Db.MInstansiSet.CountAsync(x => !x.NonAktif);
        _customer = await Db.MCustomerSet.CountAsync(x => !x.NonAktif);
        _nomor = await Db.MNomorWhatsappSet.CountAsync(x => !x.NonAktif);
        _grup = await Db.MGrupWhatsappSet.CountAsync(x => !x.NonAktif);
        _latestInstansi = await Db.MInstansiSet.AsNoTracking().OrderByDescending(x => x.TglSinkronTerakhir ?? x.TglBuat).Take(25).ToListAsync();
    }

    private bool FilterInstansi(VPointCare.Web.Data.Entities.MInstansi row)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }

        return Contains(row.KodeInstansi)
            || Contains(row.NamaInstansi)
            || Contains(row.Kota)
            || Contains(row.SumberData)
            || Contains(row.TglSinkronTerakhir?.ToString("dd/MM/yyyy HH:mm"));
    }

    private bool Contains(string? value) => value?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true;
}
