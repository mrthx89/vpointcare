@page "/admin/pengaturan/jobs"
@attribute [Authorize]
@inject VPointCare.Web.Data.VPointCareDbContext Db
@inject AuthenticationStateProvider AuthStateProvider
@inject IConfiguration Configuration
@inject ISnackbar Snackbar
@inject VPointCare.Web.Services.Jobs.HangfireRecurringJobScheduler JobScheduler
@using Microsoft.EntityFrameworkCore
@using VPointCare.Web.Data.Entities

<PageTitle>Pengaturan Jobs - VPoint Care</PageTitle>

<MudStack Spacing="3">
    <div class="page-heading-row">
        <div>
            <MudText Typo="Typo.h5">Pengaturan Jobs</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Atur jadwal dan status aktif job Hangfire dari database.</MudText>
        </div>
        <MudButton Href="/admin/jobs" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.WorkHistory">Dashboard Hangfire</MudButton>
    </div>

    @if (!_canManage)
    {
        <MudAlert Severity="Severity.Error">Hanya user dengan peran ROOT atau ADMIN yang dapat mengubah pengaturan job.</MudAlert>
    }
    else
    {
        <MudPaper Class="section-panel" Elevation="0">
            <MudText Typo="Typo.subtitle1">Recurring Job</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Format jadwal menggunakan cron 5 kolom, contoh: <code>*/5 * * * *</code>.</MudText>
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Job</th>
                        <th>Hangfire ID</th>
                        <th>Cron</th>
                        <th>Status</th>
                        <th>Aksi</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in _rows)
                    {
                        <tr>
                            <td>
                                <strong>@row.NamaJob</strong>
                                <div>@row.KodeJob</div>
                                <div>@row.Keterangan</div>
                            </td>
                            <td>
                                <MudTextField @bind-Value="row.JobIdHangfire" Margin="Margin.Dense" Variant="Variant.Outlined" />
                            </td>
                            <td>
                                <MudTextField @bind-Value="row.CronExpression" Margin="Margin.Dense" Variant="Variant.Outlined" />
                            </td>
                            <td>
                                <MudSwitch T="bool" @bind-Value="row.Aktif" Color="Color.Success">@(row.Aktif ? "Aktif" : "Nonaktif")</MudSwitch>
                            </td>
                            <td>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Save" OnClick="@(() => SaveAsync(row))">Simpan</MudButton>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </MudPaper>
    }
</MudStack>

@code {
    private bool _canManage;
    private List<JobSettingRow> _rows = [];

    protected override async Task OnInitializedAsync()
    {
        _canManage = await CanManageAsync();
        if (!_canManage)
        {
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _rows = await Db.MPengaturanHangfireJobSet
            .AsNoTracking()
            .Where(x => !x.NonAktif)
            .OrderBy(x => x.NamaJob)
            .Select(x => new JobSettingRow
            {
                Id = x.Id,
                KodeJob = x.KodeJob,
                NamaJob = x.NamaJob,
                JobIdHangfire = x.JobIdHangfire,
                CronExpression = x.CronExpression,
                Aktif = x.Aktif,
                Keterangan = x.Keterangan
            })
            .ToListAsync();
    }

    private async Task SaveAsync(JobSettingRow row)
    {
        if (string.IsNullOrWhiteSpace(row.JobIdHangfire))
        {
            Snackbar.Add("Hangfire ID wajib diisi.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(row.CronExpression))
        {
            Snackbar.Add("Cron wajib diisi.", Severity.Warning);
            return;
        }

        var entity = await Db.MPengaturanHangfireJobSet.FirstOrDefaultAsync(x => x.Id == row.Id);
        if (entity is null)
        {
            Snackbar.Add("Setting job tidak ditemukan.", Severity.Error);
            return;
        }

        entity.JobIdHangfire = row.JobIdHangfire.Trim();
        entity.CronExpression = row.CronExpression.Trim();
        entity.Aktif = row.Aktif;
        entity.TglEdit = DateTime.UtcNow;

        await Db.SaveChangesAsync();

        if (!string.IsNullOrWhiteSpace(Configuration.GetConnectionString("Hangfire")))
        {
            await JobScheduler.SyncAsync();
            Snackbar.Add("Pengaturan job tersimpan dan jadwal Hangfire diterapkan.", Severity.Success);
            return;
        }

        Snackbar.Add("Pengaturan job tersimpan. Hangfire belum aktif karena connection string Hangfire kosong.", Severity.Warning);
    }

    private async Task<bool> CanManageAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.IsInRole("ROOT") || user.IsInRole("ADMIN"))
        {
            return true;
        }

        var roleIdText = user.FindFirst("peran_id")?.Value;
        if (!Guid.TryParse(roleIdText, out var roleId))
        {
            return false;
        }

        var roleCode = await Db.Perans
            .AsNoTracking()
            .Where(x => x.Id == roleId && !x.NonAktif)
            .Select(x => x.KodePeran)
            .FirstOrDefaultAsync();

        return string.Equals(roleCode, "ROOT", StringComparison.OrdinalIgnoreCase)
            || string.Equals(roleCode, "ADMIN", StringComparison.OrdinalIgnoreCase);
    }

    private sealed class JobSettingRow
    {
        public Guid Id { get; set; }
        public string KodeJob { get; set; } = "";
        public string NamaJob { get; set; } = "";
        public string JobIdHangfire { get; set; } = "";
        public string CronExpression { get; set; } = "";
        public bool Aktif { get; set; }
        public string? Keterangan { get; set; }
    }
}
