@page "/admin/pengaturan/jobs"
@attribute [Authorize]
@inject VPointCare.Web.Data.VPointCareDbContext Db
@inject AuthenticationStateProvider AuthStateProvider
@inject IConfiguration Configuration
@inject ISnackbar Snackbar
@inject VPointCare.Web.Services.Jobs.HangfireRecurringJobScheduler JobScheduler
@inject VPointCare.Web.Services.Auth.PermissionService PermissionService
@using Microsoft.EntityFrameworkCore
@using VPointCare.Web.Data.Entities
@using VPointCare.Web.Services.Auth

<PageTitle>Pengaturan Jobs - VPoint Care</PageTitle>

<MudStack Spacing="3">
    <div class="page-heading-row">
        <div>
            <MudText Typo="Typo.h5">Pengaturan Jobs</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Atur jadwal dan status aktif job Hangfire dari database.</MudText>
        </div>
        <MudButton Href="/admin/jobs" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.WorkHistory">Dashboard Hangfire</MudButton>
    </div>

    @if (!_canManage)
    {
        <MudAlert Severity="Severity.Error">User tidak memiliki hak akses Pengaturan Jobs.</MudAlert>
    }
    else
    {
        <MudPaper Class="section-panel" Elevation="0">
            <MudText Typo="Typo.subtitle1">Recurring Job</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">Format jadwal menggunakan cron 5 kolom, contoh: <code>*/5 * * * *</code>.</MudText>
            <MudTable T="JobSettingRow" Items="@_rows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" RowsPerPage="10" Filter="FilterRow">
                <ToolBarContent>
                    <MudText Typo="Typo.subtitle1">Data Jadwal Job</MudText>
                    <MudSpacer />
                    <MudTextField @bind-Value="_search" Placeholder="Filter data" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Margin="Margin.Dense" Variant="Variant.Outlined" />
                </ToolBarContent>
                <HeaderContent>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobSettingRow, object>(x => x.NamaJob)">Job</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobSettingRow, object>(x => x.JobIdHangfire)">Hangfire ID</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobSettingRow, object>(x => x.CronExpression)">Cron</MudTableSortLabel></MudTh>
                    <MudTh><MudTableSortLabel SortBy="new Func<JobSettingRow, object>(x => x.Aktif)">Status</MudTableSortLabel></MudTh>
                    <MudTh>Aksi</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Job">
                        <MudText Typo="Typo.body2"><strong>@context.NamaJob</strong></MudText>
                        <MudText Typo="Typo.caption">@context.KodeJob</MudText>
                        <MudText Typo="Typo.caption">@context.Keterangan</MudText>
                    </MudTd>
                    <MudTd DataLabel="Hangfire ID">
                        <MudTextField @bind-Value="context.JobIdHangfire" Margin="Margin.Dense" Variant="Variant.Outlined" />
                    </MudTd>
                    <MudTd DataLabel="Cron">
                        <MudTextField @bind-Value="context.CronExpression" Margin="Margin.Dense" Variant="Variant.Outlined" />
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudSwitch T="bool" @bind-Value="context.Aktif" Color="Color.Success">@(context.Aktif ? "Aktif" : "Nonaktif")</MudSwitch>
                    </MudTd>
                    <MudTd DataLabel="Aksi">
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" StartIcon="@Icons.Material.Filled.Save" OnClick="@(() => SaveAsync(context))">Simpan</MudButton>
                    </MudTd>
                </RowTemplate>
                <PagerContent>
                    <MudTablePager PageSizeOptions="new[] { 10, 25, 50, 100 }" />
                </PagerContent>
            </MudTable>
        </MudPaper>
    }
</MudStack>

@code {
    private bool _canManage;
    private List<JobSettingRow> _rows = [];
    private string _search = "";

    protected override async Task OnInitializedAsync()
    {
        _canManage = await CanManageAsync();
        if (!_canManage)
        {
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _rows = await Db.MPengaturanHangfireJobSet
            .AsNoTracking()
            .Where(x => !x.NonAktif)
            .OrderBy(x => x.NamaJob)
            .Select(x => new JobSettingRow
            {
                Id = x.Id,
                KodeJob = x.KodeJob,
                NamaJob = x.NamaJob,
                JobIdHangfire = x.JobIdHangfire,
                CronExpression = x.CronExpression,
                Aktif = x.Aktif,
                Keterangan = x.Keterangan
            })
            .ToListAsync();
    }

    private async Task SaveAsync(JobSettingRow row)
    {
        if (string.IsNullOrWhiteSpace(row.JobIdHangfire))
        {
            Snackbar.Add("Hangfire ID wajib diisi.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(row.CronExpression))
        {
            Snackbar.Add("Cron wajib diisi.", Severity.Warning);
            return;
        }

        var entity = await Db.MPengaturanHangfireJobSet.FirstOrDefaultAsync(x => x.Id == row.Id);
        if (entity is null)
        {
            Snackbar.Add("Setting job tidak ditemukan.", Severity.Error);
            return;
        }

        entity.JobIdHangfire = row.JobIdHangfire.Trim();
        entity.CronExpression = row.CronExpression.Trim();
        entity.Aktif = row.Aktif;
        entity.TglEdit = DateTime.UtcNow;

        await Db.SaveChangesAsync();

        if (!string.IsNullOrWhiteSpace(Configuration.GetConnectionString("Hangfire")))
        {
            await JobScheduler.SyncAsync();
            Snackbar.Add("Pengaturan job tersimpan dan jadwal Hangfire diterapkan.", Severity.Success);
            return;
        }

        Snackbar.Add("Pengaturan job tersimpan. Hangfire belum aktif karena connection string Hangfire kosong.", Severity.Warning);
    }

    private async Task<bool> CanManageAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        return await PermissionService.HasPermissionAsync(authState.User, AppPermissions.MenuPengaturanJobs);
    }

    private bool FilterRow(JobSettingRow row)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }

        return Contains(row.KodeJob)
            || Contains(row.NamaJob)
            || Contains(row.JobIdHangfire)
            || Contains(row.CronExpression)
            || Contains(row.Keterangan)
            || Contains(row.Aktif ? "Aktif" : "Nonaktif");
    }

    private bool Contains(string? value) => value?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true;

    private sealed class JobSettingRow
    {
        public Guid Id { get; set; }
        public string KodeJob { get; set; } = "";
        public string NamaJob { get; set; } = "";
        public string JobIdHangfire { get; set; } = "";
        public string CronExpression { get; set; } = "";
        public bool Aktif { get; set; }
        public string? Keterangan { get; set; }
    }
}
