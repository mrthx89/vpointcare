@page "/admin/users"
@attribute [Authorize]
@inject VPointCare.Web.Data.VPointCareDbContext Db
@using Microsoft.EntityFrameworkCore

<PageTitle>MUser - VPoint Care</PageTitle>

<MudStack Spacing="3">
    <div>
        <MudText Typo="Typo.h5">MUser</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">User login hasil migrasi dari tabel Laravel `users`, terhubung ke `MPengguna`.</MudText>
    </div>

    <MudGrid>
        <MudItem xs="12" sm="4"><MudPaper Class="metric-tile" Elevation="0"><MudIcon Icon="@Icons.Material.Filled.ManageAccounts" /><span>MUser</span><strong>@_users</strong></MudPaper></MudItem>
        <MudItem xs="12" sm="4"><MudPaper Class="metric-tile" Elevation="0"><MudIcon Icon="@Icons.Material.Filled.Person" /><span>MPengguna</span><strong>@_pengguna</strong></MudPaper></MudItem>
        <MudItem xs="12" sm="4"><MudPaper Class="metric-tile" Elevation="0"><MudIcon Icon="@Icons.Material.Filled.AdminPanelSettings" /><span>Peran</span><strong>@_roles</strong></MudPaper></MudItem>
    </MudGrid>

    <MudPaper Class="section-panel" Elevation="0">
        <div class="section-header-row">
            <MudText Typo="Typo.subtitle1">User Login</MudText>
            <MudButton Href="/admin/users/pengguna" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.PeopleAlt">Pengguna Internal</MudButton>
        </div>
        <MudTable T="UserRow" Items="@_rows" Dense="true" Hover="true" Breakpoint="Breakpoint.Sm" RowsPerPage="10" Filter="FilterRow">
            <ToolBarContent>
                <MudText Typo="Typo.subtitle1">Data User Login</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="_search" Placeholder="Filter data" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" Margin="Margin.Dense" Variant="Variant.Outlined" />
            </ToolBarContent>
            <HeaderContent>
                <MudTh><MudTableSortLabel SortBy="new Func<UserRow, object>(x => x.Name)">Nama</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<UserRow, object>(x => x.Email)">Email</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<UserRow, object>(x => x.Status)">Status</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<UserRow, object>(x => x.NamaPengguna)">Pengguna Internal</MudTableSortLabel></MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<UserRow, object?>(x => x.LoginTerakhir)">Login Terakhir</MudTableSortLabel></MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Nama">@context.Name</MudTd>
                <MudTd DataLabel="Email">@context.Email</MudTd>
                <MudTd DataLabel="Status">@context.Status</MudTd>
                <MudTd DataLabel="Pengguna Internal">@context.NamaPengguna</MudTd>
                <MudTd DataLabel="Login Terakhir">@(context.LoginTerakhir?.ToString("dd/MM/yyyy HH:mm") ?? "-")</MudTd>
            </RowTemplate>
            <PagerContent>
                <MudTablePager PageSizeOptions="new[] { 10, 25, 50, 100 }" />
            </PagerContent>
        </MudTable>
    </MudPaper>
</MudStack>

@code {
    private int _users;
    private int _pengguna;
    private int _roles;
    private List<UserRow> _rows = [];
    private string _search = "";

    protected override async Task OnInitializedAsync()
    {
        _users = await Db.Users.CountAsync();
        _pengguna = await Db.Penggunas.CountAsync();
        _roles = await Db.Perans.CountAsync();
        _rows = await (
            from user in Db.Users.AsNoTracking()
            join pengguna in Db.Penggunas.AsNoTracking() on user.Id equals pengguna.IdUser into penggunaJoin
            from pengguna in penggunaJoin.DefaultIfEmpty()
            orderby user.Name
            select new UserRow(user.Name, user.Email, user.Status, pengguna == null ? "-" : pengguna.NamaPengguna, pengguna == null ? null : pengguna.LoginTerakhirPada))
            .ToListAsync();
    }

    private bool FilterRow(UserRow row)
    {
        if (string.IsNullOrWhiteSpace(_search))
        {
            return true;
        }

        return Contains(row.Name)
            || Contains(row.Email)
            || Contains(row.Status)
            || Contains(row.NamaPengguna)
            || Contains(row.LoginTerakhir?.ToString("dd/MM/yyyy HH:mm"));
    }

    private bool Contains(string? value) => value?.Contains(_search, StringComparison.OrdinalIgnoreCase) == true;

    private sealed record UserRow(string Name, string Email, string Status, string NamaPengguna, DateTime? LoginTerakhir);
}
